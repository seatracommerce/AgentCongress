# Frontend build/deploy: set these when building or deploying.
# Copy to frontend/.env.local for local dev, or pass --api-url when using deploy-frontend.sh.
#
# Required at build time (baked into client bundle):
NEXT_PUBLIC_API_URL=https://agentcongress-backend-xxxx.run.app

# Use your actual Cloud Run (or other) backend URL. No trailing slash.
