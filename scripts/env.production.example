# Copy to .env.production and fill in values. Use with:
#   ./scripts/deploy-backend.sh --project YOUR_PROJECT_ID --region us-central1 --env-vars-file .env.production
# Format: KEY=VALUE (no export, no quotes). Empty values are omitted by Cloud Run.
# Default region in the script is us-central1. Set GCP_PROJECT_ID or pass --project.
# For secrets, use Secret Manager and --set-secrets when deploying (see README).
#
# Database: use Cloud SQL (below) or a free-tier Postgres (Neon, Supabase). For Neon/Supabase
# set DATABASE_URL to their URI with postgresql+asyncpg:// and no CLOUD_SQL_INSTANCE on deploy.

ENV=production
# Required when ENV=production (Secret Manager). Use your GCP project ID (e.g. agentcongress), not project number.
GCP_PROJECT_ID=agentcongress
DISABLE_SCHEDULER=true
# Cloud SQL (use with CLOUD_SQL_INSTANCE when deploying):
# DATABASE_URL=postgresql+asyncpg://user:pass@/dbname?host=/cloudsql/PROJECT:REGION:INSTANCE
# Free tier (Neon / Supabase). Use postgresql+asyncpg:// (or postgresql:// – app will use asyncpg either way)
DATABASE_URL=postgresql+asyncpg://user:pass@host/dbname?sslmode=require
WEBAPP_URL=https://your-frontend-url.com

# Optional: protect /admin/trigger-poll and task workers
SCHEDULER_SECRET=your-secret-here

# Optional: Twitter (set DRY_RUN=false to post)
DRY_RUN=true
# TWITTER_API_KEY=...
# TWITTER_API_SECRET=...
# TWITTER_ACCESS_TOKEN=...
# TWITTER_ACCESS_SECRET=...

# Cloud Tasks (when using POST /admin/schedule-poll)
# CLOUD_TASKS_PROJECT_ID=agentcongress
# CLOUD_TASKS_LOCATION=us-central1
# CLOUD_TASKS_QUEUE_NAME=agentcongress
# SERVICE_URL=https://agentcongress-backend-k3u7dfffua-uc.a.run.app

# API keys: set via env or Secret Manager (ANTHROPIC_API_KEY, CONGRESS_API_KEY, etc.)
