ENV=development
ANTHROPIC_API_KEY=
CONGRESS_API_KEY=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
DATABASE_URL=postgresql+asyncpg://user:pass@localhost/agentcongress
NEXT_PUBLIC_API_URL=http://localhost:8000
DRY_RUN=true
WEBAPP_URL=https://agentcongress.example.com
# Set DISABLE_SCHEDULER=true when using Cloud Scheduler to hit POST /admin/trigger-poll
DISABLE_SCHEDULER=false
# Optional: set a secret and send it as X-Scheduler-Secret header to protect trigger-poll
SCHEDULER_SECRET=
# Cloud Tasks (optional): for POST /admin/schedule-poll to enqueue work
SERVICE_URL=
CLOUD_TASKS_PROJECT_ID=
CLOUD_TASKS_LOCATION=
CLOUD_TASKS_QUEUE_NAME=
